# Copie este arquivo para ".env" e ajuste os valores antes de rodar
# "docker-compose up". O arquivo ".env" NAO deve ser commitado (veja .gitignore).

MYSQL_ROOT_PASSWORD=troque-esta-senha
MYSQL_DATABASE=ecommerce

# Gere uma chave forte, por exemplo com: openssl rand -base64 48
JWT_KEY=troque-esta-chave-por-uma-chave-forte-e-unica
JWT_ISSUER=EcommerceApi
JWT_AUDIENCE=EcommerceApiUsers
